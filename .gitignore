# Python
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.egg-info/
*.egg
.eggs/
dist/
build/
site/
*.so
*.dylib

# Virtual environments
.venv/
venv/
env/
.env

# EPL compiled cache
*.eplc
__epl_cache__/

# PyInstaller frozen builds
epl/_internal/

# Logs
*.log
*.log.*

# OS
.DS_Store
Thumbs.db
desktop.ini

# IDE
.vscode/settings.json
.idea/
*.swp
*.swo

# VS Code extension build output
vscode-extension/node_modules/
vscode-extension/*.vsix

# Secrets — NEVER commit these
.pypirc
*.pem
*.key
*.env
.env.*
secrets.toml

# Test coverage
.coverage
htmlcov/
.pytest_cache/

# Jupyter
.ipynb_checkpoints/

# Large model files
epl/models/
*.gguf
*.bin

# Temp
tmp/
temp/
*.tmp

# Compiled / transpiled output artifacts
*.exe
*.o
*.ll
*.db

# Transpiled source output (generated by epl js/kt/py commands)
hello.js
hello.kt
hello.py
functions.js
functions.kt
functions.py
variables.py
classes.py
advanced.py

# Fuzzing output
fuzz_*.txt
fuzz_out*

# Debug/exploration temp scripts
_tmp_*.py
_tmp_*.epl

# Scratch test files in root
test[0-9]*.epl
test_[0-9]*.epl
playground_*.epl

# Release check artifacts
_release_check*/

# Compiled bytecode in root
*.eplc

# SQLite databases generated by apps
spark.db
*.db

# AI workspace config (not part of EPL source)
.agent/
.gemini/

# AI config with API keys - never commit
epl/.ai_config.json

# --- ENFORCED REPO CLEANUP ---
# Blocks all test_* files in root
/test_*.py
/test.js

# Blocks build release folders (e.g., epl_lang-7.0.0, eplang-7.4.3)
/eplang-*/
/epl_lang-*/

# Blocks root logs
/build_output.log
/test_output.log

# wrangler files
.wrangler
.dev.vars*
!.dev.vars.example
!.env.example
